# ============================================
# Configuration pour l'envoi d'emails
# ============================================

# Méthode 1: Gmail (Recommandé pour tester)
# ==================================================
# 1. Créez un compte Gmail si vous n'en avez pas
# 2. Activez la vérification en deux étapes
# 3. Générez un "mot de passe d'application" sur: https://myaccount.google.com/apppasswords
# 4. Utilisez ce mot de passe ci-dessous

EMAIL_SERVICE=gmail
EMAIL_USER=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe-application
EMAIL_FROM=votre-email@gmail.com

# Méthode 2: Service SMTP générique
# ==================================================
# Exemples: Brevo (anciennement Sendinblue), OVH, Ionos, etc.

# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=votre-email@example.com
# SMTP_PASSWORD=votre-cle-api
# EMAIL_FROM=noreply@casibio.fr

# Méthode 3: SendGrid
# ==================================================
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=SG.xxx...

# Note: Si aucune configuration d'email n'est fournie,
# le système fonctionnera quand même mais affichera juste
# les liens d'invitation dans la console du serveur.
