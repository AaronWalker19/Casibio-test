# Admin credentials - change these values
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=admin123

# Server port
PORT=3000

# MySQL Configuration (for alwaysdata.net)
# Find these in your alwaysdata.net control panel
DB_HOST=mysql-casibio.alwaysdata.net
DB_USER=casibio_user
DB_PASSWORD=your-password-here
DB_NAME=casibio_db
DB_PORT=3306

# JWT Secret (IMPORTANT: Générer une clé très sécurisée!)
# Sur PowerShell: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
# Sur Linux/Mac: openssl rand -base64 32
JWT_SECRET=YOUR-SUPER-SECRET-KEY-CHANGE-IN-PROD-MINIMUM-32-CHARS

# CORS Configuration - origines autorisées
CORS_ORIGIN=http://localhost:3000

# Node Environment
NODE_ENV=development
